# IntentSight Environment Variables
# Copy to .env and adjust as needed.

# Path to behaviour dataset CSV (overrides default search order)
# INTENTSIGHT_DATASET_PATH=./Behaviour_Extended_Dataset.csv

# Skip Kaggle download and use local CSV only
INTENTSIGHT_SKIP_KAGGLE=true

# Python
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
